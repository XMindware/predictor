{
  "info": {
    "_postman_id": "2cb54c6d-efed-4cc3-ae8e-9d3470b53353",
    "name": "Predictor API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for Predictor API v1. Supports health checks, API token issuance, and Sanctum-protected endpoints."
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health"
              ]
            },
            "description": "Public health endpoint."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var data = pm.response.json();",
                  "  pm.collectionVariables.set('apiToken', data.token);",
                  "  if (data.user && data.user.email) {",
                  "    pm.collectionVariables.set('email', data.user.email);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"token_name\": \"{{tokenName}}\",\n  \"abilities\": [\"*\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tokens",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tokens"
              ]
            },
            "description": "Exchange valid user credentials for a Sanctum bearer token. Saves the returned token into the collection variable `apiToken`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Protected",
      "item": [
        {
          "name": "GET /api/user",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{apiToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/user",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "user"
              ]
            },
            "description": "Returns the authenticated user for the supplied bearer token."
          },
          "response": []
        },
        {
          "name": "GET /api/tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var data = pm.response.json();",
                  "  if (data.data && data.data.length > 0) {",
                  "    pm.collectionVariables.set('tokenId', data.data[0].id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{apiToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tokens",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tokens"
              ]
            },
            "description": "Lists tokens owned by the authenticated user. Saves the first token id into `tokenId`."
          },
          "response": []
        },
        {
          "name": "DELETE /api/tokens/:tokenId",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{apiToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tokens/{{tokenId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tokens",
                "{{tokenId}}"
              ]
            },
            "description": "Revokes a token owned by the authenticated user. Use the `tokenId` variable or replace it manually."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "email",
      "value": "test@example.com",
      "type": "string"
    },
    {
      "key": "password",
      "value": "password",
      "type": "string"
    },
    {
      "key": "tokenName",
      "value": "postman-client",
      "type": "string"
    },
    {
      "key": "apiToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "tokenId",
      "value": "",
      "type": "string"
    }
  ]
}
